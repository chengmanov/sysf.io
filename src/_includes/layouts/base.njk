<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {% set pageTitle = title + " — " + site.name if title else site.name + " — " + site.tagline %}
    {% set pageDesc = description if description else site.shortDescription %}
    {% set canonical = (site.url + page.url) %}
    {% set ogImage = site.url + "/assets/img/og-image.svg" %}

    <title>{{ pageTitle }}</title>
    <meta name="description" content="{{ pageDesc }}" />
    <link rel="canonical" href="{{ canonical }}" />
    <meta name="theme-color" content="{{ site.themeColor }}" />
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- Open Graph -->
    <meta property="og:type" content="{{ ogType if ogType else 'website' }}" />
    <meta property="og:site_name" content="{{ site.name }}" />
    <meta property="og:title" content="{{ pageTitle }}" />
    <meta property="og:description" content="{{ pageDesc }}" />
    <meta property="og:url" content="{{ canonical }}" />
    <meta property="og:image" content="{{ ogImage }}" />
    <meta property="og:locale" content="en" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="{{ pageTitle }}" />
    <meta name="twitter:description" content="{{ pageDesc }}" />
    <meta name="twitter:image" content="{{ ogImage }}" />

    <link rel="icon" href="/assets/img/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/assets/styles.css" />

    <!-- No-flash theme init -->
    <script>
      (function () {
        try {
          var t = localStorage.getItem("theme");
          if (t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
            document.documentElement.classList.add("dark");
          }
        } catch (e) {}
      })();
    </script>

    <!-- Organization + WebSite structured data (for AI search + SEO) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": {{ site.name | dump | safe }},
      "legalName": {{ site.legalName | dump | safe }},
      "url": {{ site.url | dump | safe }},
      "email": {{ site.email | dump | safe }},
      "slogan": {{ site.tagline | dump | safe }},
      "description": {{ site.description | dump | safe }},
      "foundingDate": {{ site.foundingYear | dump | safe }},
      "logo": {{ (site.url + "/assets/img/logo.svg") | dump | safe }},
      "areaServed": ["CH", "EU"],
      "address": { "@type": "PostalAddress", "addressCountry": "CH" },
      "knowsAbout": [
        "Sovereign AI", "Fine-tuning large language models", "Apertus", "LangChain", "LangGraph",
        "Retrieval-augmented generation", "Swiss data protection (FADP)", "EU AI Act", "On-premise LLM deployment"
      ],
      "sameAs": [{{ site.social.github | dump | safe }}]
    }
    </script>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": {{ site.name | dump | safe }},
      "url": {{ site.url | dump | safe }},
      "description": {{ site.shortDescription | dump | safe }},
      "inLanguage": "en",
      "publisher": { "@type": "Organization", "name": {{ site.name | dump | safe }} }
    }
    </script>
    {% if page.url != "/" %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ site.url | dump | safe }} },
        { "@type": "ListItem", "position": 2, "name": {{ (title or site.name) | dump | safe }}, "item": {{ canonical | dump | safe }} }
      ]
    }
    </script>
    {% endif %}
    {% if faq %}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faq %}
        { "@type": "Question", "name": {{ item.q | dump | safe }}, "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} } }{% if not loop.last %},{% endif %}
        {%- endfor %}
      ]
    }
    </script>
    {% endif %}
    {% if extraSchema %}
    <script type="application/ld+json">{{ extraSchema | dump | safe }}</script>
    {% endif %}
  </head>

  <body class="min-h-screen bg-white text-ink-900 dark:bg-ink-950 dark:text-ink-300">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-swiss focus:px-4 focus:py-2 focus:text-white">Skip to content</a>

    {% include "partials/nav.njk" %}

    <main id="main">
      {{ content | safe }}
    </main>

    {% include "partials/footer.njk" %}

    <script>
      // Mobile nav toggle
      (function () {
        var btn = document.getElementById("navToggle");
        var menu = document.getElementById("mobileMenu");
        if (btn && menu) {
          btn.addEventListener("click", function () {
            var open = menu.classList.toggle("hidden") === false;
            btn.setAttribute("aria-expanded", String(open));
          });
        }
        // Theme toggle
        var themeBtns = document.querySelectorAll("[data-theme-toggle]");
        themeBtns.forEach(function (b) {
          b.addEventListener("click", function () {
            var isDark = document.documentElement.classList.toggle("dark");
            try { localStorage.setItem("theme", isDark ? "dark" : "light"); } catch (e) {}
          });
        });
      })();
    </script>
  </body>
</html>
