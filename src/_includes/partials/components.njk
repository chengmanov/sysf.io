<svg class="{{ cls or 'h-5 w-5' }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">{{ p[name] | safe }}</svg>
{%- endmacro %}

{# Teal feature-card chip housing a Lucide icon — the site's standard section/feature marker. #}
{% macro iconChip(name, cls) %}
<span class="mb-5 inline-grid h-11 w-11 place-items-center rounded-lg bg-teal-50 text-teal-700 dark:bg-white/5 dark:text-teal-300 {{ cls }}">{{ icon(name, "h-[22px] w-[22px]") }}</span>
{% endmacro %}

{#
  Resource-library card. `item` is a collection entry carrying resType/kicker/blurb;
  reports also carry `date`. Cards filter client-side by their data-restype; no-JS
  shows everything. readLabel is the localised "Read" verb.
#}
{% macro resourceCard(item, locale, readLabel) %}
{%- set typeIcon = { "concept": "cpu", "report": "bar-chart-3", "demo": "play", "note": "file-check" } -%}
<a href="{{ item.url }}" data-restype="{{ item.data.resType }}"
   class="resource-card group flex flex-col rounded-lg border border-neutral-200 bg-white p-6 shadow-sm transition hover:border-teal-600/40 hover:shadow-md dark:border-white/10 dark:bg-ink-950">
  <div class="mb-4 flex items-center justify-between gap-3">
    <span class="inline-flex items-center gap-1.5 text-[11px] font-bold uppercase tracking-[0.12em] text-teal-700 dark:text-teal-300">{{ icon(typeIcon[item.data.resType] or "file-check", "h-3.5 w-3.5") }}{{ item.data.kicker }}</span>
    {% if item.data.date %}<time class="font-mono text-[11px] text-ink-500" datetime="{{ item.data.date }}">{{ item.data.date | readableDate(locale) }}</time>{% endif %}
  </div>
  <h3 class="text-lg font-bold leading-snug tracking-tightest text-ink-900 group-hover:text-teal-700 dark:text-white dark:group-hover:text-teal-300">{{ item.data.listTitle or item.data.title }}</h3>
  <p class="mt-2 flex-1 text-sm prose-muted">{{ item.data.blurb or item.data.description }}</p>
  <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-300">{{ readLabel or "Read" }}{{ icon("arrow-right", "h-4 w-4 transition-transform group-hover:translate-x-0.5") }}</span>
</a>
{% endmacro %}

{% macro sectionHead(eyebrow, heading, sub) %}
<div class="max-w-2xl">
  {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
  <h2 class="mt-3 text-3xl font-bold tracking-tightest text-ink-900 md:text-4xl dark:text-white">{{ heading }}</h2>
  {% if sub %}<p class="mt-4 text-lg prose-muted">{{ sub | safe }}</p>{% endif %}
</div>
{% endmacro %}

{% macro faqList(items) %}
<div class="divide-y divide-ink-900/10 border-y border-ink-900/10 dark:divide-white/10 dark:border-white/10">
  {% for item in items %}
  <details class="group py-5" {% if loop.first %}open{% endif %}>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-base font-semibold text-ink-900 dark:text-white">
      <span>{{ item.q }}</span>
      <span aria-hidden="true" class="mt-1 shrink-0 text-swiss transition-transform duration-200 group-open:rotate-45">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
      </span>
    </summary>
    <div class="mt-3 max-w-3xl text-[15px] leading-relaxed prose-muted">{{ item.a | safe }}</div>
  </details>
  {% endfor %}
</div>
{% endmacro %}

{% macro cta(heading, sub, opts) %}
{% set L = opts.L if opts and opts.L else "" %}
{% set primary = opts.primary if opts and opts.primary else "Book a call" %}
{% set secondary = opts.secondary if opts and opts.secondary else "See how it works" %}
<section class="border-t border-ink-900/10 bg-ink-950 dark:border-white/10">
  <div class="container-x py-16 md:py-20">
    <div class="grid items-center gap-8 md:grid-cols-12">
      <div class="md:col-span-8">
        <h2 class="text-3xl font-bold tracking-tightest text-white md:text-4xl">{{ heading }}</h2>
        <p class="mt-4 max-w-2xl text-lg text-ink-300">{{ sub | safe }}</p>
      </div>
      <div class="flex flex-wrap gap-3 md:col-span-4 md:justify-end">
        <a href="{{ L }}/contact/" class="btn-primary">{{ primary }}</a>
        <a href="{{ L }}/platform/" class="btn-ghost border-white/20 text-white hover:border-white/50">{{ secondary }}</a>
      </div>
    </div>
  </div>
</section>
{% endmacro %}
