{% macro sectionHead(eyebrow, heading, sub) %}
<div class="max-w-2xl">
  {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
  <h2 class="mt-3 text-3xl font-bold tracking-tightest text-ink-900 md:text-4xl dark:text-white">{{ heading }}</h2>
  {% if sub %}<p class="mt-4 text-lg prose-muted">{{ sub | safe }}</p>{% endif %}
</div>
{% endmacro %}

{% macro faqList(items) %}
<div class="divide-y divide-ink-900/10 border-y border-ink-900/10 dark:divide-white/10 dark:border-white/10">
  {% for item in items %}
  <details class="group py-5" {% if loop.first %}open{% endif %}>
    <summary class="flex cursor-pointer list-none items-center justify-between gap-6 text-base font-semibold text-ink-900 dark:text-white">
      <span>{{ item.q }}</span>
      <span aria-hidden="true" class="mt-1 shrink-0 text-swiss transition-transform duration-200 group-open:rotate-45">
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" d="M12 5v14M5 12h14"/></svg>
      </span>
    </summary>
    <div class="mt-3 max-w-3xl text-[15px] leading-relaxed prose-muted">{{ item.a | safe }}</div>
  </details>
  {% endfor %}
</div>
{% endmacro %}

{% macro cta(heading, sub) %}
<section class="border-t border-ink-900/10 bg-ink-950 dark:border-white/10">
  <div class="container-x py-16 md:py-20">
    <div class="grid items-center gap-8 md:grid-cols-12">
      <div class="md:col-span-8">
        <h2 class="text-3xl font-bold tracking-tightest text-white md:text-4xl">{{ heading }}</h2>
        <p class="mt-4 max-w-2xl text-lg text-ink-300">{{ sub | safe }}</p>
      </div>
      <div class="flex flex-wrap gap-3 md:col-span-4 md:justify-end">
        <a href="/contact/" class="btn-primary">Book a call</a>
        <a href="/platform/" class="btn-ghost border-white/20 text-white hover:border-white/50">See how it works</a>
      </div>
    </div>
  </div>
</section>
{% endmacro %}
