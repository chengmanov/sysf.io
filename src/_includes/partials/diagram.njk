{% set locale = locale or "en" %}
{% set d = i18n[locale].diagram %}
<figure class="relative">
  <figcaption class="sr-only">{{ d.caption }}</figcaption>

  <!-- Excluded external API -->
  <div class="mb-3 flex items-center justify-end gap-2 text-xs text-ink-500">
    <span class="line-through decoration-swiss decoration-2">{{ d.excluded }}</span>
    <span class="grid h-5 w-5 place-items-center border border-swiss text-swiss" aria-hidden="true">✕</span>
  </div>

  <div class="relative rounded-xl border-2 border-teal-400 bg-white p-5 shadow-md dark:bg-ink-900">
    <div class="absolute -top-3 left-4 flex items-center gap-1.5 bg-white px-2 text-xs font-semibold uppercase tracking-[0.14em] text-swiss dark:bg-ink-900">
      <span class="inline-block h-3 w-3 bg-swiss" aria-hidden="true"></span>
      {{ d.jurisdiction }}
    </div>

    <ul class="space-y-2.5">
      {% for n in d.nodes %}
      <li>
        <div class="flex items-center gap-3 rounded-md border border-neutral-200 bg-neutral-50 px-4 py-3 dark:border-white/10 dark:bg-white/[0.03]">
          <span class="font-mono text-xs text-swiss">0{{ loop.index }}</span>
          <div>
            <div class="text-sm font-semibold text-ink-900 dark:text-white">{{ n.t }}</div>
            <div class="text-xs prose-muted">{{ n.d }}</div>
          </div>
        </div>
        {% if not loop.last %}<div class="ml-4 h-2 w-px bg-swiss/40" aria-hidden="true"></div>{% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
  <p class="mt-3 text-center text-xs text-ink-500">{{ d.foot }}</p>
</figure>
