<footer class="border-t border-ink-900/10 bg-white dark:border-white/10 dark:bg-ink-950">
  <div class="container-x grid gap-10 py-14 md:grid-cols-12">
    <div class="md:col-span-5">
      <a href="/" class="flex items-center gap-2.5 text-lg font-bold tracking-tightest text-ink-900 dark:text-white" aria-label="sysf.io home">
        {% include "partials/mark.njk" %}
        <span class="font-display font-extrabold">{{ site.brandBase }}<span class="text-red-600">{{ site.brandTld }}</span></span>
      </a>
      <p class="mt-3 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">{{ site.slogan }}</p>
      <p class="mt-4 max-w-sm text-sm prose-muted"><span class="font-medium text-ink-900 dark:text-white">{{ site.descriptor }}</span> On-prem, Swiss cloud, or air-gapped — built and operated from Switzerland, and yours to run.</p>
      <p class="mt-4 text-xs text-ink-500">Built on <a class="link-underline" href="{{ site.baseModel.url }}" target="_blank" rel="noopener">Apertus</a>, Switzerland's open LLM.</p>
    </div>

    <div class="md:col-span-3 md:col-start-8">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">Explore</h2>
      <ul class="mt-4 space-y-2 text-sm">
        {% for item in site.nav %}
        <li><a class="text-ink-700 hover:text-swiss dark:text-ink-300 dark:hover:text-white" href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">Contact</h2>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a class="text-ink-700 hover:text-swiss dark:text-ink-300 dark:hover:text-white" href="mailto:{{ site.email }}">{{ site.email }}</a></li>
        <li><a class="text-ink-700 hover:text-swiss dark:text-ink-300 dark:hover:text-white" href="{{ site.social.github }}" target="_blank" rel="noopener">GitHub</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-ink-900/10 dark:border-white/10">
    <div class="container-x flex flex-col items-start justify-between gap-2 py-6 text-xs text-ink-500 sm:flex-row sm:items-center">
      <p>© {% year %} {{ site.legalName }}. Made in Switzerland.</p>
      <p>Sovereign · Data-private · Yours to run</p>
    </div>
  </div>
</footer>
