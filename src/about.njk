</section>

<!-- Principles -->
<section class="border-y border-ink-900/10 bg-ink-900/[0.02] py-20 dark:border-white/10 dark:bg-white/[0.02] md:py-28">
  <div class="container-x">
    {{ sectionHead("Principles", "How we work.") }}
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {% set vals = [
        {t:"Sovereignty first", d:"Training and inference run in your tenancy or your datacentre; Production and Air-gapped engagements have zero data egress."},
        {t:"Open over closed", d:"Open weights only — fully-Swiss Apertus by default, or a European or international base like Mistral or Qwen where your compliance allows — so auditors can inspect what they sign off."},
        {t:"Products, not demos", d:"Go-live is gated on an evaluation score agreed at scoping, not on a stakeholder demo."},
        {t:"Compliance by design", d:"FADP/GDPR mapping and EU AI Act documentation are named deliverables in the statement of work."}
      ] %}
      {% set valIcons = ["shield-check", "book-open", "package-check", "file-check"] %}
      {% for v in vals %}
      <div class="rounded-lg border border-neutral-200 bg-white p-8 shadow-sm dark:border-white/10 dark:bg-ink-950">
        {{ iconChip(valIcons[loop.index0]) }}
        <h3 class="text-base font-semibold text-ink-900 dark:text-white">{{ v.t }}</h3>
        <p class="mt-2 text-sm prose-muted">{{ v.d }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Differentiation pointer -->
<section class="container-x py-20 md:py-28">
