      {% set roles = [
        {t:"Fine-tuning", d:"Teaches the task: your terminology, document formats, tone, output structure, refusal behaviour. It does not reliably memorise facts — using it as a knowledge store is a design error we refuse to ship."},
        {t:"Retrieval (RAG)", d:"Supplies the facts: the current version of your policies, contracts and records, cited back to the source page. Knowledge updates the moment the document does — no retraining."},
        {t:"The ablation", d:"Every Pilot scores all four arms — base, retrieval, fine-tune, combined — on your evaluation set. The table says which system is worth buying."}
      ] %}
      {% set roleIcons = ["sliders-horizontal", "database", "bar-chart-3"] %}
