{{ cta("Prefer to just talk it through?", "Skip the form — book a 30-minute scoping call and we'll map your first use case together.") }}

<script>
(function () {
  "use strict";
  var CONTACT_EMAIL = "{{ site.email }}";

  // ---- Selected-state class tokens (must appear literally so Tailwind emits them) ----
  // Important variants so they beat the card's base dark:bg-ink-950 / dark:border-white/10.
  var SEL = ["ring-2", "ring-teal-500", "!border-teal-500", "!bg-teal-50", "dark:!bg-teal-500/10", "dark:!border-teal-500"];

  // ---- Question bank -------------------------------------------------------
  var Q = {
    sector: { title: "Which sector are you in?", type: "single", cols: 2, hint: "Pick the closest — it shapes the tasks, systems and compliance we design for.", opts: [
      { id: "banking", label: "Banking & Finance", imp: "Client identifying data and Art. 47 secrecy — on-prem or confidential compute, zero egress, audit rights and an exit plan documented." },
      { id: "healthcare", label: "Healthcare & Pharma", imp: "Special-category data under nFADP / GDPR, KIS integration via HL7-FHIR. Outside MDR scope by design — no diagnostic or triage function." },
      { id: "legal", label: "Legal & Professional Services", imp: "Privilege-safe and in-jurisdiction — contract analysis, multilingual research and drafting on your own templates and precedent." },
      { id: "government", label: "Government & Public Sector", imp: "Runs on national infrastructure, data never leaves the country — the pattern the Canton of Ticino runs in production at 94% accuracy." },
      { id: "insurance", label: "Insurance", imp: "FINMA-compliant outsourcing from day one — claims, policy Q&A and correspondence against core systems like Guidewire or SAP FS-CM." },
      { id: "manufacturing", label: "Manufacturing & Industrial", imp: "On-prem / edge-friendly and protects operational IP — copilots over your manuals, SOPs and specs." },
      { id: "other", label: "Something else", imp: "Name it in the box — the method is the same: measure on your data, ship the smallest model that clears the bar." }
    ]},
    task: { title: "What's the primary task?", type: "single", cols: 2, hint: "This is what we'd tune and measure first.", opts: [
      { id: "qa", label: "Document & regulatory Q&A", imp: "Retrieval-first: answers grounded in your documents, with citations. The eval set is built from real questions your teams ask." },
      { id: "extract", label: "Extraction & classification", imp: "Fine-tuning locks the output format so every result is machine-parseable and lands cleanly in your systems." },
      { id: "draft", label: "Drafting & correspondence", imp: "Tuned on your templates and house style — drafts in your voice, in the right language, ready to edit." },
      { id: "intake", label: "Intake & triage", imp: "Routes and structures incoming cases by pairing a small tuned model with your business rules — not a black box." },
      { id: "coding", label: "Domain coding (ICD/CHOP, clause tags…)", imp: "A narrow, measurable task where a tuned 4–8B beats a general API — and stays inside your walls." },
      { id: "other", label: "Something else", imp: "Describe it in a line — if it's measurable, we can build to it. If it isn't measurable yet, that's the first thing we'd fix together." }
    ]},
    audience: { title: "Who will use it, roughly?", type: "single", cols: 2, hint: "Scale changes the hardening, not the principle.", opts: [
      { id: "team", label: "A small team (< 25)", imp: "Start focused — a Pilot on one workflow with the people who feel the pain daily is the cheapest honest test." },
      { id: "dept", label: "A department (25–200)", imp: "Worth wiring into the systems the department already lives in — access control and audit trails from day one." },
      { id: "org", label: "Organisation-wide (200+)", imp: "Scale argues for Production hardening: monitoring, an evaluation cadence and a support agreement." },
      { id: "external", label: "Customer- or citizen-facing", imp: "External users raise the bar: tested guardrails, PII discipline and fallbacks become part of the scope, not an option." }
    ]},
    languages: { title: "Which languages must it handle?", type: "multi", cols: 3, note: "All four national languages natively — including Swiss German — plus English. No translation layer in the loop.", opts: [
      { id: "de", label: "German" }, { id: "fr", label: "French" }, { id: "it", label: "Italian" },
      { id: "rm", label: "Romansh" }, { id: "gsw", label: "Swiss German" }, { id: "en", label: "English" },
      { id: "other", label: "Other" }
    ]},
    dataVolume: { title: "Roughly how much material will it work over?", type: "single", cols: 2, hint: "A rough bucket is fine — it mostly affects retrieval engineering, not model size.", opts: [
      { id: "small", label: "Under 1,000 documents", imp: "Plenty for retrieval and a focused eval set (50–300 tasks). Fine-tuning data is curated, not bulk." },
      { id: "med", label: "1,000 – 100k documents", imp: "Comfortable for a production retrieval index; we sample a representative eval set from it." },
      { id: "large", label: "100k – millions", imp: "We shard the index and add re-ranking. Volume is a retrieval-engineering problem, not a reason for a bigger model." },
      { id: "unsure", label: "Not sure yet", imp: "Fine — we size the index and eval set together during scoping." }
    ]},
    dataFormats: { title: "What shape is the source material?", type: "multi", cols: 2, note: "Format drives the pipeline: born-digital text is straightforward; scans add an OCR stage we test like everything else; structured data often wants tools and queries, not embeddings.", opts: [
      { id: "digital", label: "Digital documents (PDF, Office)" },
      { id: "scans", label: "Scanned paper / images (needs OCR)" },
      { id: "structured", label: "Structured data (DB exports, tables)" },
      { id: "comms", label: "Email, tickets, chat logs" },
      { id: "other", label: "Something else" }
    ]},
    dataLocation: { title: "Where does that data live today?", type: "single", cols: 3, note: "Where your data lives decides where the model runs — it comes to the data, never the other way around.", opts: [
      { id: "onprem", label: "Our datacentre / servers" },
      { id: "swisscloud", label: "Swiss cloud tenancy" },
      { id: "mixed", label: "Mixed / to be decided" }
    ]},
    pii: { title: "Does it contain PII that must be handled before the model sees it?", type: "single", cols: 2, note: "PII handling is a tested guardrail, not an afterthought — redaction / minimisation runs in the pipeline and we measure that it holds. This isn't legal advice; we work with your compliance team.", opts: [
      { id: "none", label: "No sensitive PII" },
      { id: "redact", label: "Yes — redact before processing" },
      { id: "pseudo", label: "Yes — pseudonymise / tokenise" },
      { id: "unsure", label: "Not sure" }
    ]},
    model: { title: "Which model family should we start from?", type: "single", cols: 2, opts: [
      { id: "apertus", label: "Apertus", sub: "Recommended · Swiss", imp: "Switzerland's fully open LLM from EPFL, ETH Zurich and CSCS — open weights and documented training data, exactly what auditors want to see. Our default, and the Canton of Ticino production reference." },
      { id: "llama", label: "Llama", sub: "Meta · open weights", imp: "Meta's open-weight family — a strong general contender we regularly test, with sizes in both our classes. If it wins on your evaluation set, it ships; the weights still live in your infrastructure." },
      { id: "mistral", label: "Mistral", sub: "European · open weights", imp: "European open-weight models and a frequent contender on multilingual tasks. Same rule: it ships only if it wins your evaluation." },
      { id: "eval", label: "Let the evaluation decide", sub: "How we'd do it", imp: "We benchmark Apertus, Llama and Mistral on a set built from your documents and ship the winner — you see the numbers before anything ships." },
      { id: "other", label: "Another open-weight model", imp: "Name it in the box — if the weights are open and it runs in your jurisdiction, it can enter the evaluation." }
    ]},
    size: { title: "Model size class", type: "single", cols: 2, opts: [
      { id: "s8", label: "4–8B · workstation class", sub: "~24–48 GB VRAM", imp: "Runs at interactive speed on a single workstation-class GPU server (roughly 24–48 GB of VRAM). The production sweet spot for a narrow, well-defined task — and the class the Ticino system runs in." },
      { id: "s70", label: "70B · node class", sub: "multi-GPU", imp: "For broader reasoning or as a local escalation target — needs a multi-GPU node or a confidential-compute instance. Escalation stays local, never to a cloud API." },
      { id: "unsure", label: "Not sure", imp: "We pick the smallest model that clears your eval bar. Smaller is cheaper, faster and easier to run — the calculator below assumes 4–8B until we scope it." }
    ]},
    quant: { title: "Quantization", type: "single", cols: 3, opts: [
      { id: "fp16", label: "16-bit", sub: "full precision", imp: "Reference quality and the biggest footprint — 2 bytes per weight. Useful as the evaluation baseline; rarely what we ship." },
      { id: "q4", label: "4-bit", sub: "recommended", imp: "The production sweet spot — GGUF K-quants at roughly 4.5 bits per weight. Re-evaluated after quantizing; if quality drops, we don't ship it." },
      { id: "q12", label: "1–2 bit", sub: "frontier", imp: "The ternary / binary frontier — needs quantization-aware training, and ships only if it clears your evaluation bar. 8B weights drop to ~2 GB — less than half of 4-bit." }
    ]},
    approach: { title: "How should it get good at your task?", type: "single", cols: 2, opts: [
      { id: "base", label: "Base model only", imp: "The open model as shipped — a baseline to measure against, rarely the answer on its own." },
      { id: "rag", label: "+ Retrieval (RAG)", imp: "Grounds answers in your documents. Knowledge updates the moment a document does — no retraining." },
      { id: "ft", label: "+ Fine-tune (LoRA)", imp: "Teaches your terminology, formats and task behaviour. It does NOT reliably memorise facts — we never use it as a knowledge store." },
      { id: "both", label: "Fine-tune + Retrieval", sub: "Recommended", imp: "The full system: retrieval supplies the facts, fine-tuning locks the format and voice. On our FINMA benchmark this doubles the production bar over retrieval alone." }
    ]},
    deployment: { title: "Where should it run?", type: "single", cols: 2, opts: [
      { id: "swisscloud", label: "Dedicated Swiss cloud", imp: "Single-tenant, in-jurisdiction, under a data-processing agreement. A clean path for a Pilot." },
      { id: "onprem_ws", label: "On-prem workstation", imp: "A single workstation-class GPU server in your datacentre — a tuned 4–8B on a CHF 5–15k machine." },
      { id: "onprem_node", label: "On-prem node", imp: "A multi-GPU node for larger models or higher throughput, entirely inside your walls." },
      { id: "airgapped", label: "Air-gapped / confidential compute", imp: "Fully isolated — updates arrive as signed, checksummed offline bundles. Pull the network cable, keep working." }
    ]},
    integration: { title: "How should it plug into your runtime?", type: "multi", cols: 2, note: "The model is the engine; orchestration wires it to your systems with access control, audit trails and PII discipline. The framework is plumbing — the hardening is the product.", opts: [
      { id: "chat", label: "Standalone chat interface" },
      { id: "api", label: "An API into our existing apps" },
      { id: "systems", label: "Into a core system (HL7-FHIR, Guidewire, SAP…)" },
      { id: "agents", label: "Agents & tools (MCP)" },
      { id: "other", label: "Something else" }
    ]},
    ongoing: { title: "How much do you want us to run afterwards?", type: "single", cols: 1, opts: [
      { id: "pilot", label: "One-off Pilot, then hand it over", imp: "You own the model and run it independently. A documented handover is the deliverable — your exit strategy is in scope." },
      { id: "production", label: "Production with monitoring & support", imp: "We monitor for drift, evaluate on a cadence and maintain the system under a support agreement." },
      { id: "managed", label: "Managed ongoing retraining", imp: "We re-run fine-tuning as your data grows or a stronger open base ships. Facts still update through retrieval instantly — retraining is for behaviour, not knowledge." }
    ]},
    timeline: { title: "When does this need to be real?", type: "single", cols: 2, hint: "An honest timeline gets an honest answer.", opts: [
      { id: "exploring", label: "Just exploring", imp: "Good — this configurator plus a short call is exactly the cheap way to explore." },
      { id: "quarter", label: "Pilot in the next 3 months", imp: "Realistic — a Pilot is scoped in weeks, not quarters." },
      { id: "year", label: "Production this year", imp: "We'd sequence Pilot → Production and bring your infrastructure and compliance teams in early." },
      { id: "urgent", label: "Urgent — we have a deadline", imp: "Put the date in the notes. We'll tell you honestly what fits before it — and what doesn't." }
    ]},
    frameworks: { title: "Which regimes apply?", type: "multi", cols: 2, note: "In-jurisdiction deployment addresses the Swiss FADP / nFADP and EU GDPR; documented data lineage and tested guardrails support your EU AI Act obligations. Not legal advice — we work alongside your compliance and legal teams.", opts: [
      { id: "fadp", label: "Swiss FADP / nFADP" },
      { id: "gdpr", label: "EU GDPR" },
      { id: "aiact", label: "EU AI Act" },
      { id: "unsure", label: "Not sure yet" }
    ]},
    compliancePack: { title: "Include the compliance & audit pack?", type: "single", cols: 2, note: "The pack: model card, training-data lineage record, data-processing agreement template, technical & organisational measures (TOMs), EU AI Act risk-classification worksheet, and the evaluation report.", opts: [
      { id: "yes", label: "Yes, include it" },
      { id: "no", label: "Not needed" },
      { id: "unsure", label: "Undecided" }
    ]},
    nextStep: { title: "What should happen after you send this?", type: "single", cols: 2, opts: [
      { id: "call", label: "A 30-minute scoping call", imp: "We come prepared with your spec; you leave with the shape of a fixed-scope proposal." },
      { id: "written", label: "A short written reaction first", imp: "We reply to your spec by email with an honest read — including a clear no if this isn't the right fit — before any call." }
    ]}
  };

  // Placeholders for the free-text "Other" inputs.
  var OTHER_PLACEHOLDER = {
    sector: "Your sector — e.g. energy, logistics, education…",
    task: "Describe the task in one line",
    languages: "Which language(s)?",
    dataFormats: "What format is it in?",
    model: "Which model? (open weights)",
    integration: "What should it plug into?"
  };

  // ---- Steps ---------------------------------------------------------------
  var STEPS = [
    { eyebrow: "01 · Use case", title: "What are you building, and for whom?", intro: "Start with the shape of the work. There are no wrong answers — this scopes where we begin.", questions: ["sector", "task", "audience"] },
    { eyebrow: "02 · Languages", title: "The languages your work actually happens in.", intro: "Multilingual isn't a feature here — it's the default. Pick everything your documents and your users actually use.", questions: ["languages"] },
    { eyebrow: "03 · Your data", title: "The data you can't send away.", intro: "This is the whole point — so we ask about it carefully, starting with what it looks like and where it lives.", questions: ["dataVolume", "dataFormats", "dataLocation", "pii"] },
    { eyebrow: "04 · Model & approach", title: "Pick the engine — and watch it fit.", intro: "This is the fun part. Change the size and quantization and watch the model shrink onto your hardware; change the approach and watch the measured accuracy floor move.", questions: ["model", "size", "quant", "approach"], widgets: true },
    { eyebrow: "05 · Deployment", title: "Where it runs, and how it plugs in.", intro: "The model comes to the data — never the other way around. This step decides what that means physically.", questions: ["deployment", "integration"] },
    { eyebrow: "06 · Ongoing", title: "One-off, maintained, or managed.", intro: "Everything we build is yours either way — the question is how much of the running you want to keep us around for.", questions: ["ongoing", "timeline"] },
    { eyebrow: "07 · Compliance", title: "The paperwork your auditors will ask for.", intro: "Compliance is built into the architecture, then documented — auditors read the pack, regulators recognise it.", questions: ["frameworks", "compliancePack"] },
    { eyebrow: "08 · You", title: "Where should we send the proposal?", intro: "Your answers have stayed in your browser this whole time. They only leave when you press send.", questions: ["nextStep"], contact: true }
  ];

  // ---- Static reference data ----------------------------------------------
  // Weights-only memory, GB — same numbers as /concepts/quantization/:
  // 8B: 16 GB (16-bit) → ~4.5 GB (4-bit K-quants) → ~2 GB (1–2 bit)
  // 70B: 140 GB → ~40 GB → ~18 GB (70e9 × 2 bits ≈ 17.5)
  var GB = { s8: { fp16: 16, q4: 4.5, q12: 2 }, s70: { fp16: 140, q4: 40, q12: 18 }, unsure: { fp16: 16, q4: 4.5, q12: 2 } };
  var GB_MAX = 140;
  var PARAM_LABEL = { s8: "8B", s70: "70B", unsure: "8B" };
  var BITS_LABEL = { fp16: "16 bits", q4: "~4.5 bits", q12: "~2 bits" };
  var QUANT_SHORT = { fp16: "16-bit", q4: "4-bit", q12: "1–2 bit" };

  // Measured on the public FINMA benchmark (183 items, deterministic scoring).
  var ABLATION = [
    { id: "base", label: "Base model" },
    { id: "rag", label: "+ Retrieval" },
    { id: "ft", label: "+ Fine-tune" },
    { id: "both", label: "Fine-tune + Retrieval" }
  ];
  var ABL_VALUES = {
    prod: { base: 0, rag: 22.4, ft: 1.6, both: 45.4 },
    ans:  { base: 37.2, rag: 63.4, ft: 44.8, both: 80.9 }
  };

  // ---- State ---------------------------------------------------------------
  var state = { model: "apertus", size: "s8", quant: "q4", approach: "both", languages: [], dataFormats: [], integration: [], frameworks: [], other: {}, contact: {} };
  var metric = "prod"; // ablation widget view toggle — not part of the brief
  var cur = 0;

  // ---- DOM refs ------------------------------------------------------------
  var stepContainer = document.getElementById("stepContainer");
  var progressFill = document.getElementById("progressFill");
  var progressLabel = document.getElementById("progressLabel");
  var progressPct = document.getElementById("progressPct");
  var backBtn = document.getElementById("backBtn");
  var nextBtn = document.getElementById("nextBtn");
  var summaryList = document.getElementById("summaryList");
  var tierChip = document.getElementById("tierChip");
  var builder = document.getElementById("builder");
  var specPrint = document.getElementById("specPrint");
  var specBody = document.getElementById("specBody");

  // ---- Helpers -------------------------------------------------------------
  function esc(s) { return String(s == null ? "" : s).replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;"); }
  function optOf(qk, oid) { return Q[qk].opts.filter(function (x) { return x.id === oid; })[0]; }
  function labelOf(qk, oid) { var o = oid && optOf(qk, oid); return o ? o.label : ""; }
  function isSel(qk, oid) {
    var v = state[qk];
    return Q[qk].type === "multi" ? (v || []).indexOf(oid) > -1 : v === oid;
  }
  function anySel(qk) { return (state[qk] || []).length > 0; }
  function hasOther(qk) { return Q[qk].opts.some(function (o) { return o.id === "other"; }); }
  // Single-select label, with the free-text detail folded in when "Other" is picked.
  function labelWithOther(qk) {
    var l = labelOf(qk, state[qk]);
    if (state[qk] === "other" && state.other[qk]) l += " — " + state.other[qk];
    return l;
  }
  // Multi-select labels joined, with "Other" expanded to its free text.
  function multiWithOther(qk) {
    return (state[qk] || []).map(function (id) {
      if (id === "other" && state.other[qk]) return "Other — " + state.other[qk];
      return labelOf(qk, id);
    }).join(", ");
  }
  function familyLabel() {
    var m = { apertus: "Apertus", llama: "Llama", mistral: "Mistral", eval: "Eval-decided" }[state.model];
    if (m) return m;
    return state.other.model ? "Other — " + state.other.model : "Other";
  }

  var CHECK = '<svg data-check class="h-4 w-4 shrink-0 text-teal-600 dark:text-teal-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

  function optionHtml(qk, o) {
    var sel = isSel(qk, o.id);
    var selCls = sel ? " " + SEL.join(" ") : "";
    var sub = o.sub ? '<span class="mt-0.5 block text-xs font-semibold uppercase tracking-[0.1em] text-teal-600 dark:text-teal-300">' + esc(o.sub) + '</span>' : "";
    return '<button type="button" data-qk="' + qk + '" data-oid="' + o.id + '" role="' + (Q[qk].type === "multi" ? "checkbox" : "radio") + '" aria-checked="' + (sel ? "true" : "false") +
      '" class="option-card group flex items-start justify-between gap-3 rounded-lg border border-neutral-200 bg-white p-4 text-left shadow-xs transition hover:border-teal-400 dark:border-white/10 dark:bg-ink-950' + selCls + '">' +
      '<span class="min-w-0"><span class="block text-sm font-semibold text-ink-900 dark:text-white">' + esc(o.label) + '</span>' + sub + '</span>' +
      '<span class="mt-0.5">' + CHECK + '</span>' +
      '</button>';
  }

  function questionHtml(qk) {
    var q = Q[qk];
    var gridCols = q.cols === 1 ? "grid-cols-1" : q.cols === 3 ? "grid-cols-1 sm:grid-cols-3" : "grid-cols-1 sm:grid-cols-2";
    var opts = q.opts.map(function (o) { return optionHtml(qk, o); }).join("");
    var impText = "";
    if (q.type === "multi") { impText = anySel(qk) ? (q.note || "") : (q.hint || ""); }
    else { impText = state[qk] ? (optOf(qk, state[qk]).imp || q.note || "") : (q.hint || q.note || ""); }
    var otherField = "";
    if (hasOther(qk)) {
      otherField = '<div data-otherwrap="' + qk + '" class="mt-3' + (isSel(qk, "other") ? "" : " hidden") + '">' +
        '<input data-otherfor="' + qk + '" type="text" value="' + esc(state.other[qk] || "") + '" placeholder="' + esc(OTHER_PLACEHOLDER[qk] || "Tell us more") + '"' +
        ' class="w-full max-w-md rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white" />' +
        '</div>';
    }
    return '<fieldset class="mt-8" data-qfield="' + qk + '">' +
      '<legend class="text-base font-bold tracking-tight text-ink-900 dark:text-white">' + esc(q.title) + '</legend>' +
      (q.type === "multi" ? '<p class="mt-1 text-xs text-ink-500">Choose any that apply.</p>' : "") +
      '<div class="mt-3 grid gap-3 ' + gridCols + '">' + opts + '</div>' +
      otherField +
      '<p data-imp="' + qk + '" class="mt-3 min-h-[1.25rem] text-sm prose-muted">' + esc(impText) + '</p>' +
      '</fieldset>';
  }

  // ---- Interactive widgets (step 04) --------------------------------------
  function widgetsHtml() {
    var barRows = ABLATION.map(function (a) {
      var v = ABL_VALUES[metric][a.id];
      return '<div class="flex items-center gap-3">' +
        '<span class="w-40 shrink-0 text-sm font-medium text-ink-900 dark:text-white">' + a.label + '</span>' +
        '<div class="relative h-6 flex-1 overflow-hidden rounded bg-neutral-100 dark:bg-white/[0.06]">' +
        '<div data-arm="' + a.id + '" class="h-full rounded bg-teal-500 transition-[width,background-color] duration-300" style="width: ' + v + '%"></div>' +
        '</div>' +
        '<span data-armval="' + a.id + '" class="w-12 shrink-0 text-right font-mono text-xs font-semibold tabular-nums text-ink-900 dark:text-white">' + v + '%</span>' +
        '</div>';
    }).join("");
    return '<div class="mt-10 grid gap-5 md:grid-cols-2">' +
      // memory-fit
      '<figure class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950">' +
        '<figcaption class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-500">Fits in memory</figcaption>' +
        '<div class="mt-4 flex items-baseline gap-2">' +
          '<span id="memGb" class="font-mono text-4xl font-bold tabular-nums text-ink-900 dark:text-white md:text-5xl">4.5</span>' +
          '<span class="text-lg font-semibold text-ink-500">GB</span>' +
        '</div>' +
        '<p id="memFormula" class="mt-1 font-mono text-xs tabular-nums text-ink-500">8B weights × ~4.5 bits ≈ 4.5 GB</p>' +
        '<div class="relative mt-4 h-2.5 w-full overflow-hidden rounded-full bg-neutral-100 dark:bg-white/[0.06]">' +
          '<div id="memBar" class="h-full rounded-full bg-teal-500 transition-[width] duration-300" style="width: 3%"></div>' +
          '<div class="pointer-events-none absolute inset-y-0 w-px bg-ink-900/25 dark:bg-white/30" style="left: 17.1%"></div>' +
          '<div class="pointer-events-none absolute inset-y-0 w-px bg-ink-900/25 dark:bg-white/30" style="left: 34.3%"></div>' +
        '</div>' +
        '<div class="relative mt-1 h-4 font-mono text-[10px] text-ink-500">' +
          '<span class="absolute left-0">0</span>' +
          '<span class="absolute" style="left: 17.1%; transform: translateX(-50%)">24</span>' +
          '<span class="absolute" style="left: 34.3%; transform: translateX(-50%)">48</span>' +
          '<span class="absolute right-0">140 GB</span>' +
        '</div>' +
        '<div id="memVerdict" class="mt-3 inline-flex items-center gap-2 rounded-md bg-teal-50 px-3 py-1.5 text-xs font-semibold text-teal-700 dark:bg-teal-500/10 dark:text-teal-200">Fits workstation class (24–48 GB VRAM, CHF 5–15k)</div>' +
        '<p id="memAssume" class="mt-2 min-h-[1rem] text-xs prose-muted"></p>' +
        '<p class="mt-2 text-xs prose-muted">Weights only — the 24 &amp; 48 GB ticks mark the workstation band. The KV cache is a second budget that grows with context; we quantize it to 4-bit too.</p>' +
      '</figure>' +
      // ablation
      '<figure class="rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950">' +
        '<figcaption class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-500">Measured accuracy floor</figcaption>' +
        '<div class="mt-3 inline-flex overflow-hidden rounded-md border border-neutral-300 dark:border-white/15" role="group" aria-label="Metric">' +
          '<button type="button" data-metric="prod" aria-pressed="true" class="px-3 py-1.5 text-xs font-semibold transition bg-teal-600 text-white">Answer + citation</button>' +
          '<button type="button" data-metric="ans" aria-pressed="false" class="px-3 py-1.5 text-xs font-semibold transition bg-white text-ink-700 dark:bg-ink-950 dark:text-ink-300">Answer only</button>' +
        '</div>' +
        '<div class="mt-4 space-y-2.5">' + barRows + '</div>' +
        '<p id="ablationCap" class="mt-4 border-t border-neutral-200 pt-3 text-xs prose-muted dark:border-white/10"></p>' +
      '</figure>' +
    '</div>' +
    '<p class="mt-4 text-xs prose-muted">The math: <a class="link-underline" href="/concepts/quantization/">quantization, explained</a> · The experiment: <a class="link-underline" href="/reports/finma-ablation/">the FINMA ablation</a> — 183 verified questions, deterministic scoring, harness open-sourced.</p>';
  }

  function updateMemory() {
    var sizeKey = state.size || "s8";
    var q = state.quant || "q4";
    var gb = (GB[sizeKey] || GB.s8)[q];
    var memGb = document.getElementById("memGb");
    if (!memGb) return;
    memGb.textContent = gb;
    document.getElementById("memFormula").textContent = PARAM_LABEL[sizeKey] + " weights × " + BITS_LABEL[q] + " ≈ " + gb + " GB";
    document.getElementById("memBar").style.width = Math.max(2, Math.round(gb / GB_MAX * 100)) + "%";
    // The verdict respects the size CLASS, not just raw GB — 70B is node-class
    // positioning even when frontier quants shrink the weights (24–48 GB VRAM and
    // the CHF 5–15k figure belong to the 4–8B workstation class only).
    var verdict, fits = true;
    if (sizeKey === "s70") {
      fits = false;
      verdict = q === "q12"
        ? gb + " GB of weights at the frontier — could bring 70B toward single-GPU range, but it ships only if it clears your eval bar"
        : "Node class — needs a multi-GPU server or a confidential-compute instance";
    } else if (gb <= 24) verdict = "Fits a single 24 GB GPU — workstation class (CHF 5–15k)";
    else if (gb <= 48) verdict = "Fits workstation class (24–48 GB VRAM, CHF 5–15k)";
    else { verdict = "Needs a multi-GPU node or confidential-compute instance"; fits = false; }
    if (sizeKey !== "s70" && q === "q12") verdict += " · frontier — ships only if it clears your eval bar";
    var memVerdict = document.getElementById("memVerdict");
    memVerdict.textContent = verdict;
    // one-red rule: the heavier case goes neutral, not red
    memVerdict.className = "mt-3 inline-flex items-center gap-2 rounded-md px-3 py-1.5 text-xs font-semibold " +
      (fits ? "bg-teal-50 text-teal-700 dark:bg-teal-500/10 dark:text-teal-200" : "bg-neutral-100 text-ink-700 dark:bg-white/10 dark:text-ink-300");
    document.getElementById("memAssume").textContent = sizeKey === "unsure" ? "Assuming 4–8B until we scope it together." : "";
  }

  function updateAblation() {
    var pick = state.approach;
    ABLATION.forEach(function (a) {
      var bar = document.querySelector('[data-arm="' + a.id + '"]');
      if (!bar) return;
      var v = ABL_VALUES[metric][a.id];
      bar.style.width = v + "%";
      bar.className = "h-full rounded transition-[width,background-color] duration-300 " + (a.id === pick ? "bg-red-600" : "bg-teal-500");
      var val = document.querySelector('[data-armval="' + a.id + '"]');
      if (val) val.textContent = v + "%";
    });
    // toggle buttons
    stepContainer.querySelectorAll("[data-metric]").forEach(function (b) {
      var on = b.getAttribute("data-metric") === metric;
      b.setAttribute("aria-pressed", on ? "true" : "false");
      b.className = "px-3 py-1.5 text-xs font-semibold transition " + (on ? "bg-teal-600 text-white" : "bg-white text-ink-700 dark:bg-ink-950 dark:text-ink-300");
    });
    var cap = document.getElementById("ablationCap");
    if (!cap) return;
    var metricLine = metric === "prod"
      ? "Production bar: correct answer AND the exact citation, on our public FINMA benchmark. A floor, not a ceiling."
      : "Answer-only: correct answer, citation not required — the softer bar. Same benchmark, same runs.";
    var lead = "";
    if (pick === "ft") lead = "Fine-tuning alone barely moves the citation bar — it teaches format and terminology, not facts. Pair it with retrieval and it doubles. ";
    else if (pick === "both") lead = "The full system: retrieval supplies the facts, fine-tuning locks the format. ";
    else if (pick === "rag") lead = "Retrieval alone reaches 22.4% on the production bar — real value, and often the right first step. ";
    else if (pick === "base") lead = "The open model as shipped — this is why nobody should deploy a base model on a regulated task. ";
    cap.textContent = lead + metricLine;
  }

  // ---- Contact step --------------------------------------------------------
  function inputHtml(field, label, type, req) {
    var c = state.contact[field] || "";
    return '<label class="block">' +
      '<span class="text-sm font-medium text-ink-900 dark:text-white">' + label + (req ? ' <span class="text-red-600">*</span>' : "") + '</span>' +
      '<input data-field="' + field + '" type="' + type + '" value="' + esc(c) + '"' + (req ? ' required' : "") +
      ' class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white" />' +
      '</label>';
  }
  function contactHtml() {
    var c = state.contact;
    return '<div class="mt-8 grid gap-5">' +
      '<div class="grid gap-5 sm:grid-cols-2">' + inputHtml("name", "Name", "text", true) + inputHtml("email", "Work email", "email", true) + '</div>' +
      inputHtml("org", "Organisation", "text", false) +
      '<label class="block"><span class="text-sm font-medium text-ink-900 dark:text-white">Anything to add?</span>' +
      '<textarea data-field="notes" rows="3" maxlength="600" placeholder="Deadlines, systems, constraints, the thing you\'re actually worried about…" class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white">' + esc(c.notes || "") + '</textarea></label>' +
      '<p id="contactMsg" role="alert" class="min-h-[1rem] text-sm font-semibold text-red-700 dark:text-red-400"></p>' +
      '<p class="text-xs text-ink-500">Sending opens your own email client with the spec pre-filled — nothing is stored on a server.</p>' +
      '</div>';
  }

  // ---- Render --------------------------------------------------------------
  function renderStep(skipFocus) {
    var step = STEPS[cur];
    var pct = Math.round((cur + 1) / STEPS.length * 100);
    progressFill.style.width = pct + "%";
    progressLabel.textContent = "Step " + (cur + 1) + " / " + STEPS.length;
    progressPct.textContent = pct + "%";

    var html = '<p class="eyebrow">' + step.eyebrow + '</p>';
    html += '<h2 id="stepHeading" tabindex="-1" class="mt-3 text-2xl font-bold tracking-tightest text-ink-900 outline-none md:text-3xl dark:text-white">' + esc(step.title) + '</h2>';
    if (step.intro) html += '<p class="mt-3 max-w-2xl text-base prose-muted">' + esc(step.intro) + '</p>';
    if (step.questions) step.questions.forEach(function (qk) { html += questionHtml(qk); });
    if (step.widgets) html += widgetsHtml();
    if (step.contact) html += contactHtml();
    stepContainer.innerHTML = html;

    if (step.widgets) { updateMemory(); updateAblation(); }
    // check-icon visibility for pre-rendered selections
    stepContainer.querySelectorAll("[data-check]").forEach(function (ck) {
      var btn = ck.closest(".option-card");
      var sel = btn && btn.getAttribute("aria-checked") === "true";
      ck.classList.toggle("hidden", !sel);
    });

    backBtn.classList.toggle("invisible", cur === 0);
    nextBtn.textContent = cur === STEPS.length - 1 ? "Generate my build spec →" : "Next →";
    // Move focus on navigation only — focusing on initial page load would scroll
    // the visitor straight past the hero.
    if (!skipFocus) {
      var h = document.getElementById("stepHeading");
      if (h) h.focus({ preventScroll: true });
    }
    updateSummary();
  }

  // ---- Selection handling (event delegation) ------------------------------
  stepContainer.addEventListener("click", function (e) {
    var mBtn = e.target.closest("[data-metric]");
    if (mBtn) { metric = mBtn.getAttribute("data-metric"); updateAblation(); return; }
    var btn = e.target.closest(".option-card");
    if (!btn) return;
    var qk = btn.getAttribute("data-qk");
    var oid = btn.getAttribute("data-oid");
    var q = Q[qk];
    if (q.type === "multi") {
      state[qk] = state[qk] || [];
      var i = state[qk].indexOf(oid);
      if (i > -1) state[qk].splice(i, 1); else state[qk].push(oid);
      paint(btn, i === -1);
      setImp(qk, anySel(qk) ? (q.note || "") : (q.hint || ""));
    } else {
      state[qk] = oid;
      btn.closest("[data-qfield]").querySelectorAll(".option-card").forEach(function (b) { paint(b, b === btn); });
      setImp(qk, optOf(qk, oid).imp || q.note || "");
      // The MDR exemption depends on intake staying administrative — say so the
      // moment the healthcare + intake combination exists, whichever came second.
      if (isHealthTriage() && (qk === "task" || qk === "sector")) setImp("task", HEALTH_TRIAGE_NOTE);
    }
    // free-text "Other" input visibility + focus
    if (hasOther(qk)) {
      var wrap = stepContainer.querySelector('[data-otherwrap="' + qk + '"]');
      if (wrap) {
        var show = isSel(qk, "other");
        wrap.classList.toggle("hidden", !show);
        if (show && oid === "other") { var inp = wrap.querySelector("input"); if (inp) inp.focus(); }
      }
    }
    if (qk === "size" || qk === "quant") updateMemory();
    if (qk === "approach") updateAblation();
    updateSummary();
  });

  stepContainer.addEventListener("input", function (e) {
    var f = e.target.getAttribute && e.target.getAttribute("data-field");
    if (f) { state.contact[f] = e.target.value; return; }
    var o = e.target.getAttribute && e.target.getAttribute("data-otherfor");
    if (o) { state.other[o] = e.target.value; updateSummary(); }
  });

  function paint(btn, on) {
    SEL.forEach(function (c) { btn.classList.toggle(c, on); });
    btn.setAttribute("aria-checked", on ? "true" : "false");
    var ck = btn.querySelector("[data-check]");
    if (ck) ck.classList.toggle("hidden", !on);
  }
  function setImp(qk, text) {
    var el = stepContainer.querySelector('[data-imp="' + qk + '"]');
    if (el) el.textContent = text;
  }

  // ---- Suggested tier ------------------------------------------------------
  function suggestTier() {
    if (state.deployment === "airgapped") return "Air-gapped";
    // A workstation deployment is exactly the Pilot entry offer — only node-class
    // hardware, ongoing commitments or scale promote the suggestion to Production.
    if (state.deployment === "onprem_node" ||
        state.ongoing === "managed" || state.ongoing === "production" ||
        state.audience === "org" || state.audience === "external") return "Production";
    return "Pilot";
  }

  // ---- Live summary --------------------------------------------------------
  function summaryRow(label, value) {
    return '<div class="flex items-baseline justify-between gap-3"><dt class="shrink-0 text-xs font-semibold uppercase tracking-[0.1em] text-ink-500">' + label + '</dt>' +
      '<dd class="min-w-0 text-right text-sm font-medium text-ink-900 dark:text-white">' + esc(value) + '</dd></div>';
  }

  function updateSummary() {
    tierChip.textContent = suggestTier();
    // Every answered question, in step order — the sidebar is the one-glance mirror of the whole build.
    var fields = [
      ["Sector", state.sector && labelWithOther("sector")],
      ["Task", state.task && labelWithOther("task")],
      ["Audience", state.audience && labelOf("audience", state.audience)],
      ["Languages", multiWithOther("languages")],
      ["Data volume", state.dataVolume && labelOf("dataVolume", state.dataVolume)],
      ["Formats", multiWithOther("dataFormats")],
      ["Data location", state.dataLocation && labelOf("dataLocation", state.dataLocation)],
      ["PII handling", state.pii && labelOf("pii", state.pii)],
      ["Model", familyLabel()],
      ["Size", labelOf("size", state.size).split(" · ")[0]],
      ["Quantization", QUANT_SHORT[state.quant]],
      ["Approach", labelOf("approach", state.approach)],
      ["Deployment", state.deployment && labelOf("deployment", state.deployment)],
      ["Integration", multiWithOther("integration")],
      ["Ongoing", state.ongoing && labelOf("ongoing", state.ongoing).split(",")[0]],
      ["Timeline", state.timeline && labelOf("timeline", state.timeline)],
      ["Compliance", multiWithOther("frameworks")],
      ["Audit pack", state.compliancePack && labelOf("compliancePack", state.compliancePack)],
      ["Next step", state.nextStep && labelOf("nextStep", state.nextStep)]
    ];
    var rows = "";
    fields.forEach(function (p) { if (p[1]) rows += summaryRow(p[0], p[1]); });
    summaryList.innerHTML = rows || '<p class="text-xs prose-muted">Your choices will appear here as you go.</p>';
  }

  // ---- Navigation ----------------------------------------------------------
  nextBtn.addEventListener("click", function () {
    if (cur === STEPS.length - 1) { generateSpec(); return; }
    cur++;
    renderStep();
    builder.scrollIntoView({ behavior: "smooth", block: "start" });
  });
  backBtn.addEventListener("click", function () {
    if (cur === 0) return;
    cur--;
    renderStep();
    builder.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  // ---- Build spec ----------------------------------------------------------
  function line(label, val) { return val ? (label + ": " + val + "\n") : ""; }
  function buildBrief() {
    var b = "";
    b += line("Sector", labelWithOther("sector"));
    b += line("Primary task", labelWithOther("task"));
    b += line("Audience", labelOf("audience", state.audience));
    b += line("Languages", multiWithOther("languages"));
    b += line("Data volume", labelOf("dataVolume", state.dataVolume));
    b += line("Data formats", multiWithOther("dataFormats"));
    b += line("Data location", labelOf("dataLocation", state.dataLocation));
    b += line("PII handling", labelOf("pii", state.pii));
    b += line("Model", state.model === "eval" ? "Evaluation-decided (Apertus / Llama / Mistral)" : labelWithOther("model"));
    b += line("Size class", labelOf("size", state.size));
    b += line("Quantization", labelOf("quant", state.quant));
    b += line("Approach", labelOf("approach", state.approach));
    b += line("Deployment", labelOf("deployment", state.deployment));
    b += line("Integration", multiWithOther("integration"));
    b += line("Ongoing", labelOf("ongoing", state.ongoing));
    b += line("Timeline", labelOf("timeline", state.timeline));
    b += line("Compliance", multiWithOther("frameworks"));
    b += line("Compliance & audit pack", labelOf("compliancePack", state.compliancePack));
    b += line("Preferred next step", labelOf("nextStep", state.nextStep));
    b += line("Scope note", isHealthTriage() ? "Administrative intake routing only — no clinical triage (outside MDR scope)" : "");
    b += line("Suggested engagement", suggestTier());
    var c = state.contact;
    b += "\nContact: " + (c.name || "") + (c.email ? " <" + c.email + ">" : "") + (c.org ? ", " + c.org : "") + "\n";
    if (c.notes) b += "Notes: " + c.notes + "\n";
    return b;
  }

  function specStat(label, value) {
    return '<div class="bg-white p-5 dark:bg-ink-950"><dd class="font-mono text-2xl font-bold tabular-nums text-ink-900 dark:text-white md:text-3xl">' + esc(value) + '</dd>' +
      '<dt class="mt-2 text-[11px] font-semibold uppercase tracking-[0.14em] text-ink-700 dark:text-ink-300">' + label + '</dt></div>';
  }
  function specSection(label, value) {
    if (!value) return "";
    return '<div class="flex flex-col gap-1 border-b border-neutral-200 py-3 last:border-0 dark:border-white/10 sm:flex-row sm:items-baseline sm:justify-between sm:gap-6">' +
      '<dt class="text-xs font-semibold uppercase tracking-[0.1em] text-ink-500 sm:w-48 sm:shrink-0">' + label + '</dt>' +
      '<dd class="text-sm text-ink-800 dark:text-ink-200 sm:flex-1 sm:text-right">' + esc(value) + '</dd></div>';
  }

  function modelStatValue() {
    if (state.model === "eval") return "Eval-decided";
    if (state.model === "apertus") {
      if (state.size === "s8") return "Apertus 8B";
      if (state.size === "s70") return "Apertus 70B";
      return "Apertus";
    }
    if (state.model === "other") {
      var t = state.other.model || "Custom";
      return t.length > 16 ? t.slice(0, 15) + "…" : t; // full name lives in the recap + brief
    }
    return { llama: "Llama", mistral: "Mistral" }[state.model] || "—";
  }
  // Healthcare + intake needs an explicit scope note — the site's MDR exemption
  // rests on having no clinical triage function.
  function isHealthTriage() { return state.sector === "healthcare" && state.task === "intake"; }
  var HEALTH_TRIAGE_NOTE = "Healthcare intake is scoped to administrative routing and structuring only — no clinical triage or prioritisation, which keeps the system outside MDR scope by design.";

  function generateSpec() {
    var floor = ABL_VALUES.prod[state.approach] != null ? ABL_VALUES.prod[state.approach] : ABL_VALUES.prod.both;
    var approachLabel = labelOf("approach", state.approach);
    var quantShort = QUANT_SHORT[state.quant] || labelOf("quant", state.quant);
    var deployShort = labelOf("deployment", state.deployment) || "To scope";
    var headTask = (state.task === "other" && state.other.task) ? state.other.task : (labelOf("task", state.task) || "Sovereign AI build");
    var headSector = (state.sector === "other" && state.other.sector) ? state.other.sector : labelOf("sector", state.sector);

    var html = "";
    html += '<p class="eyebrow"><svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="m9 15 2 2 4-4"/></svg> Your build spec</p>';
    html += '<h2 class="mt-3 text-3xl font-bold tracking-tightest text-ink-900 md:text-4xl dark:text-white">' + esc(headTask) + (headSector ? ' for ' + esc(headSector) : "") + '</h2>';
    html += '<p class="mt-3 max-w-2xl text-base prose-muted">A structured starting point — not a quote. Send it over and we\'ll come back with a fixed-scope proposal after a short call.</p>';
    if (isHealthTriage()) html += '<p class="mt-3 max-w-2xl border-l-2 border-teal-500 pl-3 text-sm prose-muted">' + esc(HEALTH_TRIAGE_NOTE) + '</p>';

    // headline stats
    html += '<dl class="mt-8 grid gap-px overflow-hidden rounded-xl border border-neutral-200 bg-neutral-200 dark:border-white/10 dark:bg-white/10 grid-cols-2 lg:grid-cols-4">' +
      specStat("Model", modelStatValue()) +
      specStat("Quantization", quantShort) +
      specStat("Approach", approachLabel) +
      specStat("Deployment", deployShort) +
      '</dl>';

    // ablation floor
    html += '<figure class="mt-6 rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950 md:p-8">' +
      '<figcaption class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-500">Measured production floor · ' + esc(approachLabel) + '</figcaption>' +
      '<div class="mt-4 flex items-center gap-4">' +
      '<span class="font-mono text-4xl font-bold tabular-nums text-ink-900 dark:text-white md:text-5xl">' + floor + '%</span>' +
      '<div class="relative h-6 flex-1 overflow-hidden rounded bg-neutral-100 dark:bg-white/[0.06]"><div class="h-full rounded bg-red-600" style="width: ' + floor + '%"></div></div>' +
      '</div>' +
      '<figcaption class="mt-4 border-t border-neutral-200 pt-3 text-xs prose-muted dark:border-white/10">Correct answer + exact citation on our public FINMA benchmark (answer-only: ' + ABL_VALUES.ans[state.approach] + '%). A floor, not a ceiling — your data and metrics set the real target.</figcaption>' +
      '</figure>';

    // recap
    html += '<dl class="mt-6 rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950 md:p-8">' +
      specSection("Audience", labelOf("audience", state.audience)) +
      specSection("Languages", multiWithOther("languages")) +
      specSection("Data volume", labelOf("dataVolume", state.dataVolume)) +
      specSection("Source formats", multiWithOther("dataFormats")) +
      specSection("Data location", labelOf("dataLocation", state.dataLocation)) +
      specSection("PII handling", labelOf("pii", state.pii)) +
      specSection("Model", state.model === "other" ? (state.other.model || "Custom open-weight model") : "") +
      specSection("Size class", labelOf("size", state.size)) +
      specSection("Runtime integration", multiWithOther("integration")) +
      specSection("Ongoing", labelOf("ongoing", state.ongoing)) +
      specSection("Timeline", labelOf("timeline", state.timeline)) +
      specSection("Compliance regimes", multiWithOther("frameworks")) +
      specSection("Compliance & audit pack", labelOf("compliancePack", state.compliancePack)) +
      specSection("Preferred next step", labelOf("nextStep", state.nextStep)) +
      '</dl>';

    // tier + next
    html += '<div class="mt-6 rounded-xl border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950 md:p-8">' +
      '<div class="flex flex-wrap items-center gap-3"><span class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-500">Suggested engagement</span>' +
      '<span class="inline-flex items-center rounded-full border border-teal-600/30 bg-teal-50 px-3 py-1 text-sm font-bold text-teal-700 dark:border-teal-300/20 dark:bg-teal-500/10 dark:text-teal-200">' + suggestTier() + '</span></div>' +
      '<ul class="mt-4 space-y-2 text-sm prose-muted">' +
      // What-happens-next honours the visitor's own choice of next step.
      (state.nextStep === "written"
        ? ['A written reaction to this spec by email — an honest read before any call', 'A fixed-scope proposal on your data — within one week', 'A clear no in that first email if a fine-tuned open model isn\'t the right fit']
        : ['A 30-minute call with the engineer who will build your system', 'A fixed-scope proposal on your data — within one week', 'A clear no by minute 20 if a fine-tuned open model isn\'t the right fit']
      ).map(function (x) {
        return '<li class="flex items-start gap-2.5"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 bg-swiss"></span>' + x + '</li>';
      }).join("") + '</ul>' +
      '</div>';

    // actions
    html += '<div id="specActions" class="mt-8 flex flex-wrap items-center gap-3">' +
      '<button id="sendBtn" type="button" class="btn-primary">Send to sysf.io →</button>' +
      '<button id="copyBtn" type="button" class="btn-ghost">Copy brief</button>' +
      '<button id="printBtn" type="button" class="btn-ghost">Print / save as PDF</button>' +
      '<button id="editBtn" type="button" class="btn-secondary">← Edit answers</button>' +
      '<span id="actionMsg" class="text-sm text-ink-500" role="status" aria-live="polite"></span>' +
      '</div>';

    specBody.innerHTML = html;
    builder.classList.add("hidden");
    specPrint.classList.remove("hidden");
    document.documentElement.classList.add("spec-ready");
    specPrint.scrollIntoView({ behavior: "smooth", block: "start" });

    document.getElementById("sendBtn").addEventListener("click", sendBrief);
    document.getElementById("copyBtn").addEventListener("click", copyBrief);
    document.getElementById("printBtn").addEventListener("click", function () { window.print(); });
    document.getElementById("editBtn").addEventListener("click", function () {
      specPrint.classList.add("hidden");
      document.documentElement.classList.remove("spec-ready");
      builder.classList.remove("hidden");
      cur = STEPS.length - 1;
      renderStep();
      builder.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }

  function msg(t) { var m = document.getElementById("actionMsg"); if (m) m.textContent = t; }

  function sendBrief() {
    var c = state.contact;
    if (!c.name || !c.email) {
      // Bounce back to the contact step with a VISIBLE explanation there —
      // #actionMsg lives inside the spec section we're about to hide.
      specPrint.classList.add("hidden");
      document.documentElement.classList.remove("spec-ready");
      builder.classList.remove("hidden");
      cur = STEPS.length - 1;
      renderStep();
      var cm = document.getElementById("contactMsg");
      if (cm) cm.textContent = "Add your name and work email, then generate the spec again — it sends from there.";
      var email = stepContainer.querySelector('[data-field="' + (c.name ? "email" : "name") + '"]');
      if (email) email.focus();
      builder.scrollIntoView({ behavior: "smooth", block: "start" });
      return;
    }
    var subject = "Build spec — " + (c.org || c.name);
    var body = "Here's the build spec I configured on sysf.io:\n\n" + buildBrief();
    var url = "mailto:" + CONTACT_EMAIL + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
    // Some mail clients silently truncate very long mailto URLs (~2k chars).
    // If we're over budget, trim the free-text notes from the email and point at Copy brief.
    if (url.length > 1900 && c.notes) {
      var shortBrief = buildBrief().replace(/\nNotes: [\s\S]*$/, "\nNotes: (trimmed for email length — ask me, or I'll paste them)\n");
      url = "mailto:" + CONTACT_EMAIL + "?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent("Here's the build spec I configured on sysf.io:\n\n" + shortBrief);
      msg("Long notes were trimmed from the email — use Copy brief for the full version.");
    }
    window.location.href = url;
  }

  function copyBrief() {
    var text = "sysf.io build spec\n\n" + buildBrief();
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(function () { msg("Copied to clipboard."); }, function () { msg("Couldn't copy — select and copy manually."); });
    } else { msg("Clipboard unavailable — use Print instead."); }
  }

  // ---- Go ------------------------------------------------------------------
  renderStep(true);
})();
</script>
