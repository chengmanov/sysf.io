---
layout: layouts/base.njk
order: 5
title: Contact
description: Book a scoping call with sysf.io to map your first sovereign AI use case — custom models fine-tuned on Apertus, deployed in your Swiss or EU jurisdiction, or on-prem.
ogType: website
---
{% from "partials/components.njk" import icon %}
<section class="container-x py-16 md:py-24">
  <div class="grid gap-14 md:grid-cols-12">
    <!-- Left -->
    <div class="md:col-span-5">
      <p class="eyebrow">Contact</p>
      <h1 class="mt-4 text-4xl font-bold leading-[1.08] tracking-tightest text-ink-900 md:text-5xl dark:text-white">
        Let's scope your first sovereign use case.
      </h1>
      <p class="mt-6 text-lg prose-muted">
        Tell us the workflow and the data you can't send away. We'll come back with a fixed-scope proposal — no obligation.
      </p>

      <div class="mt-10 space-y-6">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">Email</div>
          <a class="mt-1 block text-lg font-semibold text-ink-900 link-underline dark:text-white" href="mailto:{{ site.email }}?subject=Sovereign%20AI%20enquiry">{{ site.email }}</a>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">What to expect</div>
          <ul class="mt-2 space-y-2 text-sm prose-muted">
            {% for x in ["A 30-minute call with the engineer who will build your system", "A fixed-scope Pilot proposal on your data — within one week", "A clear no by minute 20 if a fine-tuned open model isn't the right fit"] %}
            <li class="flex items-start gap-2.5"><span class="mt-0.5 shrink-0 text-teal-700 dark:text-teal-300">{{ icon("check", "h-4 w-4") }}</span>{{ x }}</li>
            {% endfor %}
          </ul>
        </div>
        <p class="text-sm text-ink-500">Based in Switzerland. Serving Swiss and EU organisations.</p>
      </div>
    </div>

    <!-- Right: form -->
    <div class="md:col-span-6 md:col-start-7">
      <div class="border border-ink-900/10 p-6 md:p-8 dark:border-white/10">
        <!--
          TODO: this static site has no backend yet. The form below composes an email via
          the visitor's mail client (works everywhere, no data leaves the page). To switch to
          hosted submissions instead: create a free endpoint at https://formspree.io, set
          action="https://formspree.io/f/YOUR-ID" method="POST" on the form, and delete the
          enquiryForm <script> block at the bottom of this file.
        -->
        <form id="enquiryForm" action="#" class="space-y-5">
          <label class="block">
            <span class="text-sm font-medium text-ink-900 dark:text-white">Name</span>
            <input type="text" name="name" required autocomplete="name"
                   class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-ink-900 dark:text-white">Organisation</span>
            <input type="text" name="organization" autocomplete="organization"
                   class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white" />
          </label>
          <label class="block">
            <span class="text-sm font-medium text-ink-900 dark:text-white">Sector</span>
            <select name="sector"
                    class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white dark:[&>option]:bg-ink-900">
              {% for s in ["Banking & Finance", "Healthcare & Pharma", "Legal", "Government & Public", "Insurance", "Manufacturing", "Other"] %}
              <option>{{ s }}</option>
              {% endfor %}
            </select>
          </label>
          <label class="block">
            <span class="text-sm font-medium text-ink-900 dark:text-white">What would you like to build?</span>
            <textarea name="message" rows="4" required
                      class="mt-1.5 w-full rounded-md border border-neutral-300 bg-white px-3 py-2.5 text-sm text-ink-900 outline-none transition focus:border-red-500 focus:ring-2 focus:ring-red-500/25 dark:border-white/15 dark:bg-ink-900 dark:text-white"></textarea>
          </label>
          <button type="submit" class="btn-primary w-full">Send enquiry</button>
          <p class="text-xs text-ink-500">Sending opens your email client — your enquiry goes directly to {{ site.email }}, nowhere else. We don't share your details.</p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  // Compose the enquiry as an email — no backend, no third-party form handler.
  (function () {
    var form = document.getElementById("enquiryForm");
    if (!form) return;
    form.addEventListener("submit", function (e) {
      e.preventDefault();
      var v = function (n) { var el = form.elements[n]; return el && el.value ? el.value.trim() : ""; };
      var subject = "Sovereign AI enquiry — " + (v("organization") || v("name"));
      var body = "Name: " + v("name") + "\nOrganisation: " + v("organization") + "\nSector: " + v("sector") + "\n\nWhat we'd like to build:\n" + v("message");
      window.location.href = "mailto:{{ site.email }}?subject=" + encodeURIComponent(subject) + "&body=" + encodeURIComponent(body);
    });
  })();
</script>
