{{ cta("Ihr Sektor ist nicht dabei?", "Wenn Sie vertrauliche Daten unter Schweizer oder EU-Regulierung verarbeiten, ist souveräne KI anwendbar. Erzählen Sie uns Ihren Use Case.", {L:"/de", primary:"Termin buchen", secondary:"So funktioniert's"}) }}
