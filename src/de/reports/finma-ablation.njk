        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          <div>
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-ink-500">Basis + RAG</div>
            <pre class="mt-2 whitespace-pre-wrap rounded bg-ink-900/[0.04] p-3 font-mono text-xs text-ink-700 dark:bg-white/[0.04] dark:text-ink-300">CHF 10 Milliarden</pre>
