  <div class="container-x flex flex-wrap items-center gap-x-8 gap-y-3 py-6 text-sm">
    <span class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-500">Conforme par conception</span>
    {% for b in ["LPD / nLPD suisse", "RGPD européen", "Documentation AI Act européen", "Juridiction suisse", "Aucune fuite de données", "Poids ouverts"] %}
    <span class="inline-flex items-center gap-2 font-medium text-ink-700 dark:text-ink-300">
      <span class="h-1.5 w-1.5 bg-swiss"></span>{{ b }}
    </span>
    {% endfor %}
  </div>
</section>

<!-- Proof stats -->
<section class="container-x py-14 md:py-20">
  {% set stats = [
    {v:"94 %", label:"Précision en production", sub:"L'Apertus-8B affiné du Canton du Tessin, en service sur l'infrastructure cantonale"},
    {v:"2×", label:"Fine-tuning + recherche", sub:"Réponse correcte + citation exacte passe de 22,4 % à 45,4 % lorsque l'affinage s'ajoute à la recherche — benchmark public FINMA, 183 questions vérifiées"},
    {v:"100 %", label:"Conformité de format", sub:"De ~2 % à 100 % de sortie exploitable par machine après l'affinage — mesuré sur le même benchmark FINMA"},
    {v:"0", label:"Octet de fuite de données", sub:"Aucune API LLM tierce à l'entraînement ou à l'inférence — la fuite nulle est architecturale, pas contractuelle"}
  ] %}
  {{ statBand(stats) }}
</section>

<!-- Problem / positioning -->
<section class="container-x py-20 md:py-28">
  <div class="grid gap-12 md:grid-cols-12">
    <div class="md:col-span-5">
      {{ sectionHead("Le problème", "Les API de pointe n'ont pas été conçues pour les équipes régulées.", "Pour les banques, hôpitaux, assureurs et organismes publics, l'IA externe n'est pas interdite — elle est lente et lourde en risque résiduel : des mois de revue juridique, des accords de traitement, des chaînes de sous-traitants, et au bout du compte un modèle que vous ne contrôlez toujours pas.") }}
    </div>
    <div class="md:col-span-6 md:col-start-7">
      <div class="grid gap-5 sm:grid-cols-2">
        {% set problems = [
          {t:"Les données échappent à votre contrôle", d:"Les invites et documents sont envoyés à des serveurs tiers dans une autre juridiction."},
          {t:"Aucune transparence", d:"Des poids fermés signifient aucune auditabilité — rédhibitoire pour les régulateurs."},
          {t:"Dépendance au fournisseur", d:"Tarifs, disponibilité et comportement du modèle peuvent changer sans préavis."},
          {t:"Bloqué au stade PoC", d:"Les démos ne survivent pas à une revue de protection des données ou de sécurité."}
        ] %}
        {% for p in problems %}
        <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-white/10 dark:bg-ink-950">
          <h3 class="text-base font-semibold text-ink-900 dark:text-white">{{ p.t }}</h3>
          <p class="mt-2 text-sm prose-muted">{{ p.d }}</p>
        </div>
        {% endfor %}
      </div>
      <p class="mt-6 text-base prose-muted">sysf.io lève le blocage : un modèle qui vous <strong class="font-semibold text-ink-900 dark:text-white">appartient</strong>, exécuté là où vos données vivent déjà.</p>
      <p class="mt-4 text-base prose-muted">Les <strong class="font-semibold text-ink-900 dark:text-white">94 % ci-dessus</strong> correspondent au <a class="link-underline" href="https://www.cscs.ch/science/computer-science-hpc/2026/apertus-powers-in-house-ai-translation-for-ticino" target="_blank" rel="noopener">service de traduction Apertus-8B affiné du Canton du Tessin</a>, en production sur l'infrastructure cantonale — <a class="link-underline" href="/fr/concepts/small-models/">lisez l'étude de cas complète</a>.</p>
    </div>
  </div>
</section>

<!-- Proof / measured results -->
<section class="border-t border-ink-900/10 py-20 dark:border-white/10 md:py-28">
  <div class="container-x grid gap-12 md:grid-cols-12 md:items-center">
    <div class="md:col-span-5">
      {{ sectionHead("Mesuré, pas promis", "Nous prouvons les chiffres avant que vous vous engagiez.", "Une ablation reproductible en quatre volets d'Apertus-8B sur des Q&amp;R relatives aux circulaires FINMA suisses, notée de façon déterministe — sans juge LLM. Le modèle de base connaît souvent la réponse, mais seuls l'affinage <em>et</em> la recherche combinés franchissent la barre de production : une réponse correcte <strong class='font-semibold text-ink-900 dark:text-white'>avec</strong> la citation juridique exacte.") }}
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/fr/reports/finma-ablation/" class="btn-ghost">Lire le rapport complet</a>
        <a href="https://github.com/chengmanov/apertus-swiss-eval/tree/main/finma" class="btn-ghost" target="_blank" rel="noopener">Reproduire sur GitHub →</a>
      </div>
    </div>
    <div class="md:col-span-7">
      {% set legend = [
        {name:"Réponse correcte", cls:"bg-teal-300"},
        {name:"Réponse + citation (barre de production)", cls:"bg-teal-600"},
        {name:"Franchit la barre", cls:"bg-red-600"}
      ] %}
      {% set groups = [
        {label:"A · Modèle de base", bars:[{v:37.2, cls:"bg-teal-300"}, {v:0.0, cls:"bg-teal-600"}]},
        {label:"B · + Recherche", bars:[{v:63.4, cls:"bg-teal-300"}, {v:22.4, cls:"bg-teal-600"}]},
        {label:"C · Affiné", bars:[{v:44.8, cls:"bg-teal-300"}, {v:1.6, cls:"bg-teal-600"}]},
        {label:"D · Affiné + recherche", note:"le système complet", bars:[{v:80.9, cls:"bg-teal-300"}, {v:45.4, cls:"bg-red-600"}]}
      ] %}
      {{ hbarChart(groups, legend, "183 questions vérifiées par des humains sur 10 circulaires FINMA (DE + EN). La barre de production — réponse <strong class='text-ink-700 dark:text-ink-300'>et</strong> citation exacte — passe de 22,4 % à 45,4 % uniquement lorsque l'affinage et la recherche sont combinés (D).") }}
