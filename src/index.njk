<!-- Proof / measured results -->
<section class="border-t border-ink-900/10 py-20 dark:border-white/10 md:py-28">
  <div class="container-x grid gap-12 md:grid-cols-12 md:items-center">
    <div class="md:col-span-5">
      {{ sectionHead("Measured, not promised", "We prove the numbers before you commit.", "A reproducible four-way ablation of Apertus-8B on Swiss FINMA circular Q&amp;A, scored deterministically — no LLM judge. The base model often knows the answer, but only fine-tuning <em>and</em> retrieval together clear the production bar: a correct answer <strong class='font-semibold text-ink-900 dark:text-white'>with</strong> the exact legal citation.") }}
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/reports/finma-ablation/" class="btn-ghost">Read the full report</a>
        <a href="https://github.com/chengmanov/apertus-swiss-eval/tree/main/finma" class="btn-ghost" target="_blank" rel="noopener">Reproduce on GitHub →</a>
      </div>
    </div>
    <div class="md:col-span-7">
      {% set legend = [
        {name:"Answer correct", cls:"bg-teal-300"},
        {name:"Answer + citation (production bar)", cls:"bg-teal-600"},
        {name:"Clears the bar", cls:"bg-red-600"}
      ] %}
      {% set groups = [
        {label:"A · Base model", bars:[{v:37.2, cls:"bg-teal-300"}, {v:0.0, cls:"bg-teal-600"}]},
        {label:"B · + Retrieval", bars:[{v:63.4, cls:"bg-teal-300"}, {v:22.4, cls:"bg-teal-600"}]},
        {label:"C · Fine-tuned", bars:[{v:44.8, cls:"bg-teal-300"}, {v:1.6, cls:"bg-teal-600"}]},
        {label:"D · Fine-tuned + retrieval", note:"the full system", bars:[{v:80.9, cls:"bg-teal-300"}, {v:45.4, cls:"bg-red-600"}]}
      ] %}
      {{ hbarChart(groups, legend, "183 human-verified questions across 10 FINMA circulars (DE + EN). The production bar — answer <strong class='text-ink-700 dark:text-ink-300'>and</strong> exact citation — goes 22.4% → 45.4% only when fine-tuning and retrieval are combined (D).") }}
    </div>
  </div>
</section>

