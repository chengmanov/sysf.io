  {% set indIcons = ["landmark", "heart-pulse", "scale", "building-2", "shield-check", "factory"] %}
  {% for ind in industries %}
  <section class="grid gap-8 py-14 md:grid-cols-12 md:py-16">
    <div class="md:col-span-4">
      {{ iconChip(indIcons[loop.index0]) }}
