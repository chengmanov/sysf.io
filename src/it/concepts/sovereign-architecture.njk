          <li class="flex gap-4 rounded-lg border border-neutral-200 bg-white p-5 shadow-sm dark:border-white/10 dark:bg-ink-950">
            <span class="font-mono text-sm text-swiss">{{ s.n }}</span>
            <div>
              <div class="font-semibold text-ink-900 dark:text-white">{{ s.t }}</div>
