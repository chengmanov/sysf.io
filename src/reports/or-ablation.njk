<!-- The four arms -->
<section class="container-x py-20 md:py-28">
  {{ sectionHead("The setup", "Four systems, one open model.", "Same Apertus-8B, quantized identically to 4-bit, served identically. The only variable is the weights. Scored deterministically — no LLM judge.") }}
