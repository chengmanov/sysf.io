---
permalink: /sitemap.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemap.org/schemas/sitemap/0.9">
  {%- set urls = ["/", "/platform/", "/concepts/", "/concepts/small-models/", "/concepts/quantization/", "/concepts/evaluation/", "/concepts/sovereign-architecture/", "/concepts/orchestration/", "/reports/finma-ablation/", "/reports/or-ablation/", "/news/", "/industries/", "/pricing/", "/about/", "/contact/"] %}
  {%- for u in urls %}
  <url>
    <loc>{{ site.url }}{{ u }}</loc>
    <changefreq>monthly</changefreq>
    <priority>{{ "1.0" if u == "/" else "0.8" }}</priority>
  </url>
  {%- endfor %}
</urlset>
